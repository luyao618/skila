{
  "name": "@luyao618/skila",
  "version": "0.1.1",
  "description": "Self-improving skill inventory controller for Claude Code: distill, version, evolve, and graduate skills via slash command + web control panel + MCP.",
  "type": "module",
  "bin": {
    "skila": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "smithery.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build-hooks": "node -e \"import('esbuild').then(({build})=>build({entryPoints:['src/feedback/collector.ts'],bundle:true,format:'cjs',platform:'node',target:'node20',minify:true,treeShaking:true,legalComments:'none',outfile:'dist/hooks/feedback-entry.cjs'}))\"",
    "postbuild": "node scripts/postbuild.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run",
    "mcp": "node dist/cli.js mcp",
    "serve": "node dist/cli.js serve",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "skill",
    "plugin",
    "mcp",
    "zettelkasten",
    "agent-memory"
  ],
  "license": "MIT",
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "echarts": "^5.5.1",
    "esbuild": "^0.24.0",
    "marked": "^15.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
